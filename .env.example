# CF_AI Environment Configuration
# cp .env.example .env && nano .env

# ── OpenAI ─────────────────────────────────────────────────────────────────
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── AI Model ───────────────────────────────────────────────────────────────
# Options: gpt-4o | gpt-4o-mini | gpt-4-turbo | o1 | o3-mini
CAI_MODEL=gpt-4o

# ── AI Observability (Phoenix) ─────────────────────────────────────────────
# Set to 1 to enable live tracing at http://localhost:6006
# Requires: pip3 install arize-phoenix openinference-instrumentation-openai
CFAI_TRACING=0

# ── Tool execution ─────────────────────────────────────────────────────────
# Max seconds a single tool call (nmap, gobuster, etc.) is allowed to run
CFAI_TOOL_TIMEOUT=300

# ── Debug ──────────────────────────────────────────────────────────────────
DEBUG_MODE=0
LOG_LEVEL=INFO

# ── Wordlists ─────────────────────────────────────────────────────────────
WORDLIST_COMMON=/usr/share/wordlists/dirb/common.txt
WORDLIST_BIG=/usr/share/wordlists/dirb/big.txt
WORDLIST_ROCKYOU=/usr/share/wordlists/rockyou.txt
WORDLIST_SUBDOMAINS=/usr/share/wordlists/subdomains-top1million-5000.txt

# ── Tool paths ─────────────────────────────────────────────────────────────
EXPLOITDB_PATH=/usr/share/exploitdb
NUCLEI_TEMPLATES_PATH=
