# CF_AI Environment Configuration
# Copy this file to .env and fill in your API keys
# cp .env.example .env && nano .env

# ── Server Configuration ───────────────────────────────────────────────────
CFAI_PORT=8888
CFAI_HOST=0.0.0.0

# ── Debug & Logging ────────────────────────────────────────────────────────
# Set DEBUG_MODE=1 only for development — never on a public VPS
DEBUG_MODE=0
LOG_LEVEL=INFO

# ── Cache ─────────────────────────────────────────────────────────────────
CACHE_MAX_SIZE=1000
CACHE_TTL=3600

# ── Telemetry ─────────────────────────────────────────────────────────────
ENABLE_TELEMETRY=0

# ── Browser Automation ────────────────────────────────────────────────────
CHROME_DRIVER_PATH=/usr/local/bin/chromedriver
HEADLESS_BROWSER=1

# ════════════════════════════════════════════════════════════════════════════
# API KEYS — Fill these in to unlock connected-services features
# ════════════════════════════════════════════════════════════════════════════

# ── Shodan API ─────────────────────────────────────────────────────────────
# Used for: connected device searching, exposed services, CVE lookup
# Get key: https://account.shodan.io  (free tier gives limited searches)
# Plans:   Free → $59/mo Membership → Enterprise
SHODAN_API_KEY=E42v7shOcpme1imIxAP54ADLAUbiKcZi

# ── HackerOne API ─────────────────────────────────────────────────────────
# Used for: bug bounty program lookup, report submission
# Get key: https://hackerone.com/settings/api_token/edit
# Your username and API token are both required
HACKERONE_USERNAME=75ngclaire
HACKERONE_API_KEY=6VcnvKlHAMRWl+mqew52aKCl5jD3ZBh8NLD1UEDXpDU=

# ── Censys API ────────────────────────────────────────────────────────────
# Used for: internet-wide host/certificate search
# Get key: https://search.censys.io/account  (free tier available)
# Requires both API ID and Secret
CENSYS_API_ID=
CENSYS_API_SECRET=

# ── VirusTotal API ────────────────────────────────────────────────────────
# Used for: file/URL/IP/domain reputation lookup
# Get key: https://www.virustotal.com/gui/my-apikey  (free tier available)
VIRUSTOTAL_API_KEY=a76494cd403f8e1e69461a7110363ea3da534c5374193661bff894b5629dbc9f

# ── Shodan Stream / Exploit DB ────────────────────────────────────────────
# Used for: exploit search, CVE lookup
EXPLOITDB_PATH=/usr/share/exploitdb

# ── Nuclei Templates ──────────────────────────────────────────────────────
# Path to custom nuclei templates (leave empty to use default ~/.nuclei-templates)
NUCLEI_TEMPLATES_PATH=

# ── Wordlists ─────────────────────────────────────────────────────────────
WORDLIST_COMMON=/usr/share/wordlists/dirb/common.txt
WORDLIST_BIG=/usr/share/wordlists/dirb/big.txt
WORDLIST_ROCKYOU=/usr/share/wordlists/rockyou.txt
WORDLIST_SUBDOMAINS=/usr/share/wordlists/subdomains-top1million-5000.txt
