# CF_AI Environment Configuration
# Copy this file to .env and modify as needed

# Server Configuration
CFAI_PORT=8888
CFAI_HOST=0.0.0.0

# Debug Mode (set to 1 for development, 0 for production)
DEBUG_MODE=0

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Cache Configuration
CACHE_MAX_SIZE=1000
CACHE_TTL=3600

# Telemetry (set to 1 to enable, 0 to disable)
ENABLE_TELEMETRY=1

# Security Tools Paths (leave empty to use system PATH)
NMAP_PATH=
GOBUSTER_PATH=
NIKTO_PATH=
SQLMAP_PATH=
HYDRA_PATH=
JOHN_PATH=
HASHCAT_PATH=

# Browser Configuration for Selenium
CHROME_DRIVER_PATH=/usr/local/bin/chromedriver
HEADLESS_BROWSER=1

# API Keys (if needed for external services)
# SHODAN_API_KEY=
# CENSYS_API_KEY=
# VIRUSTOTAL_API_KEY=