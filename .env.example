# CF_AI Environment Configuration
# cp .env.example .env && nano .env

# ── OpenAI ─────────────────────────────────────────────────────────────────
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── AI Model ───────────────────────────────────────────────────────────────
# Options: gpt-4o | gpt-4o-mini | gpt-4-turbo | o1 | o3-mini
CAI_MODEL=gpt-4o

# ── CF_AI Dashboard (your Flask dashboard at port 8889) ───────────────────
# Leave blank if running CLI and dashboard on the SAME machine.
# Set to your VPS address if running CLI on a remote Kali VM.
# Example: CFAI_DASHBOARD_URL=http://123.45.67.89:8889
CFAI_DASHBOARD_URL=

# Optional: shared secret to protect the remote save endpoint.
# Must match CFAI_API_KEY in the VPS .env if you set one.
CFAI_API_KEY=

# ── WordPress Credentials (for Plugin Logs / APIT-WP agent) ──────────────────
# Application Password (recommended — create in WP Admin > Users > Profile > Application Passwords)
# Copy the generated password exactly as shown (spaces included are fine).
WP_USER=
WP_APP_PASSWORD=

# Plain admin password — used as fallback via cookie login if no Application Password is set.
# Application Password is preferred; only set this if you cannot create an App Password.
WP_PASSWORD=

# ── AI Observability (Phoenix — optional, most users leave this off) ────────
# Set to 1 only if you want live OpenTelemetry tracing at http://localhost:6006
CFAI_TRACING=0

# ── Tool execution ─────────────────────────────────────────────────────────
# Max seconds a single tool call (nmap, gobuster, etc.) is allowed to run
CFAI_TOOL_TIMEOUT=300

# ── Debug ──────────────────────────────────────────────────────────────────
DEBUG_MODE=0
LOG_LEVEL=INFO

# ── Wordlists ─────────────────────────────────────────────────────────────
WORDLIST_COMMON=/usr/share/wordlists/dirb/common.txt
WORDLIST_BIG=/usr/share/wordlists/dirb/big.txt
WORDLIST_ROCKYOU=/usr/share/wordlists/rockyou.txt
WORDLIST_SUBDOMAINS=/usr/share/wordlists/subdomains-top1million-5000.txt

# ── Tool paths ─────────────────────────────────────────────────────────────
EXPLOITDB_PATH=/usr/share/exploitdb
NUCLEI_TEMPLATES_PATH=
