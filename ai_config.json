{
  "model": "cf_ai_engine_v1",
  "version": "6.0",
  "description": "CF_AI tool execution and response configuration",

  "prompt_injection_protection": {
    "enabled": true,
    "block_on_detect": true,
    "log_blocked": true,
    "max_input_length": 2000
  },

  "chat_engine": {
    "max_history_messages": 50,
    "response_format": "markdown",
    "always_suggest_tools": true,
    "tool_execution_confirmation": false
  },

  "tool_execution": {
    "default_timeout_seconds": 120,
    "max_timeout_seconds": 600,
    "use_cache": true,
    "cache_ttl_seconds": 1800,
    "auto_retry_on_failure": true,
    "max_retries": 2,
    "nice_priority": 10
  },

  "tool_priority_map": {
    "nmap":         { "priority": 1, "category": "network",     "timeout": 120 },
    "rustscan":     { "priority": 1, "category": "network",     "timeout": 60  },
    "masscan":      { "priority": 1, "category": "network",     "timeout": 120 },
    "gobuster":     { "priority": 2, "category": "web",         "timeout": 300 },
    "ffuf":         { "priority": 2, "category": "web",         "timeout": 300 },
    "feroxbuster":  { "priority": 2, "category": "web",         "timeout": 300 },
    "dirb":         { "priority": 2, "category": "web",         "timeout": 180 },
    "dirsearch":    { "priority": 2, "category": "web",         "timeout": 300 },
    "nikto":        { "priority": 2, "category": "web",         "timeout": 300 },
    "sqlmap":       { "priority": 3, "category": "web",         "timeout": 600 },
    "dalfox":       { "priority": 3, "category": "web",         "timeout": 300 },
    "nuclei":       { "priority": 3, "category": "vuln",        "timeout": 600 },
    "wpscan":       { "priority": 3, "category": "wordpress",   "timeout": 300 },
    "amass":        { "priority": 2, "category": "osint",       "timeout": 600 },
    "subfinder":    { "priority": 2, "category": "osint",       "timeout": 120 },
    "dnsenum":      { "priority": 2, "category": "osint",       "timeout": 120 },
    "theharvester": { "priority": 2, "category": "osint",       "timeout": 120 },
    "hydra":        { "priority": 4, "category": "password",    "timeout": 600 },
    "hashcat":      { "priority": 4, "category": "password",    "timeout": 600 },
    "john":         { "priority": 4, "category": "password",    "timeout": 600 },
    "volatility":   { "priority": 3, "category": "forensics",   "timeout": 300 },
    "binwalk":      { "priority": 3, "category": "forensics",   "timeout": 120 },
    "exiftool":     { "priority": 1, "category": "forensics",   "timeout": 30  },
    "steghide":     { "priority": 2, "category": "forensics",   "timeout": 60  },
    "gdb":          { "priority": 3, "category": "binary",      "timeout": 120 },
    "radare2":      { "priority": 3, "category": "binary",      "timeout": 120 },
    "metasploit":   { "priority": 5, "category": "exploit",     "timeout": 600 },
    "searchsploit": { "priority": 2, "category": "exploit",     "timeout": 30  }
  },

  "tool_command_templates": {
    "nmap": {
      "quick":      "nmap -T4 -F {target}",
      "full":       "nmap -sC -sV -T4 -p- {target}",
      "udp":        "nmap -sU -T4 --top-ports 100 {target}",
      "stealth":    "nmap -sS -T2 -p- {target}",
      "vuln":       "nmap --script vuln -T4 {target}"
    },
    "gobuster": {
      "default":    "gobuster dir -u {target} -w /usr/share/wordlists/dirb/common.txt -t 50 -q",
      "fast":       "gobuster dir -u {target} -w /usr/share/wordlists/dirb/big.txt -t 100 -q",
      "dns":        "gobuster dns -d {target} -w /usr/share/wordlists/subdomains-top1million-5000.txt -q"
    },
    "sqlmap": {
      "default":    "sqlmap -u {target} --batch --dbs",
      "full":       "sqlmap -u {target} --batch --dbs --tables --dump --level=3 --risk=2",
      "blind":      "sqlmap -u {target} --batch --technique=B --level=5 --risk=3"
    },
    "ffuf": {
      "dirs":       "ffuf -u {target}/FUZZ -w /usr/share/wordlists/dirb/common.txt -t 50 -mc 200,301,302,403",
      "params":     "ffuf -u {target}?FUZZ=test -w /usr/share/wordlists/dirb/common.txt -t 50 -mc 200,301"
    },
    "nuclei": {
      "default":    "nuclei -u {target} -severity medium,high,critical -silent",
      "full":       "nuclei -u {target} -severity low,medium,high,critical",
      "wordpress":  "nuclei -u {target} -tags wordpress -severity medium,high,critical -silent"
    },
    "wpscan": {
      "default":    "wpscan --url {target} --enumerate p,t,u --plugins-detection aggressive",
      "passive":    "wpscan --url {target} --enumerate p,t,u --detection-mode passive",
      "bruteforce": "wpscan --url {target} -U {users} -P {wordlist} --max-threads 10"
    },
    "hydra": {
      "ssh":        "hydra -l {user} -P {wordlist} ssh://{target} -t 4",
      "ftp":        "hydra -l {user} -P {wordlist} ftp://{target}",
      "http_post":  "hydra -l {user} -P {wordlist} {target} http-post-form '{path}:{params}:{fail_msg}'"
    },
    "subfinder": {
      "default":    "subfinder -d {target} -all -silent",
      "with_output":"subfinder -d {target} -all -o {output}"
    },
    "amass": {
      "passive":    "amass enum -passive -d {target}",
      "active":     "amass enum -active -d {target}",
      "full":       "amass enum -d {target} -o {output}"
    },
    "dirb": {
      "default":    "dirb {target} /usr/share/wordlists/dirb/common.txt -S",
      "big":        "dirb {target} /usr/share/wordlists/dirb/big.txt -S"
    },
    "nikto": {
      "default":    "nikto -h {target} -nointeractive",
      "ssl":        "nikto -h {target} -ssl -nointeractive",
      "save":       "nikto -h {target} -o {output} -Format txt -nointeractive"
    },
    "dalfox": {
      "url":        "dalfox url {target}",
      "pipe":       "echo {target} | dalfox pipe"
    },
    "hashcat": {
      "md5":        "hashcat -m 0 {hash} {wordlist} -O",
      "sha1":       "hashcat -m 100 {hash} {wordlist} -O",
      "sha256":     "hashcat -m 1400 {hash} {wordlist} -O",
      "ntlm":       "hashcat -m 1000 {hash} {wordlist} -O",
      "bcrypt":     "hashcat -m 3200 {hash} {wordlist} -O"
    },
    "john": {
      "default":    "john {hash_file} --wordlist={wordlist}",
      "show":       "john {hash_file} --show",
      "format":     "john {hash_file} --format={format} --wordlist={wordlist}"
    }
  },

  "wordlists": {
    "common":       "/usr/share/wordlists/dirb/common.txt",
    "big":          "/usr/share/wordlists/dirb/big.txt",
    "rockyou":      "/usr/share/wordlists/rockyou.txt",
    "subdomains":   "/usr/share/wordlists/subdomains-top1million-5000.txt",
    "dns":          "/usr/share/wordlists/subdomains-top1million-20000.txt",
    "web_big":      "/usr/share/seclists/Discovery/Web-Content/big.txt",
    "web_common":   "/usr/share/seclists/Discovery/Web-Content/common.txt"
  },

  "response_templates": {
    "tool_not_found": "Tool '{tool}' is not installed. Install it with: sudo apt install {tool} -y\nAlternatives: {alternatives}",
    "permission_denied": "Permission denied. Ensure you have write access to the working directory and the tool has necessary permissions.",
    "timeout": "Command timed out after {timeout}s. Try reducing scope or increasing timeout in ai_config.json.",
    "injection_blocked": "Input blocked by CF_AI security protection. Please rephrase your request.",
    "success": "Command completed in {duration:.2f}s."
  }
}
